# ============================================
# Stream Avatar System - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# App Settings
APP_PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=generate-a-random-string-here
API_SECRET=generate-another-random-string-here

# Database
DB_USER=avatars
DB_PASS=your-db-password-here
DB_NAME=stream_avatars

# Twitch OAuth (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# YouTube OAuth (https://console.cloud.google.com/) - Optional
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# StreamElements (https://streamelements.com/dashboard/account/channels) - Optional
# Used to verify incoming SE webhooks
SE_JWT_TOKEN=your-streamelements-jwt-token

# Admin Access - Comma separated Twitch user IDs who get admin access
ADMIN_TWITCH_IDS=kindredspiritva

# Point Economy Config
POINTS_PER_WATCH_INTERVAL=10
WATCH_INTERVAL_MINUTES=10
POINTS_PER_CHAT=2
POINTS_PER_FOLLOW=50
POINTS_PER_SUB=500
POINTS_PER_GIFT_SUB=300
POINTS_PER_100_BITS=200
POINTS_PER_DOLLAR_DONATION=200
POINTS_PER_RAID=100
POINTS_PER_SUPERCHAT_DOLLAR=200
POINTS_PER_YT_MEMBERSHIP=500
